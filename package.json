{
  "name": "@drakulavich/markdownv2-cli",
  "version": "0.1.0",
  "description": "CLI to convert Markdown text or files into Telegram MarkdownV2 format using telegramify-markdown.",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "markdownv2": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/cli.ts --outfile ./dist/cli.js --target bun",
    "typecheck": "tsc --noEmit",
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "keywords": [
    "telegram",
    "markdown",
    "markdownv2",
    "cli",
    "bun",
    "telegramify-markdown"
  ],
  "author": "drakulavich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drakulavich/markdownv2-cli.git"
  },
  "dependencies": {
    "telegramify-markdown": "^1.3.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
